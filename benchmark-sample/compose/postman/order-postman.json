        {
          "name": "Create a new Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.id) {",
                  "    pm.collectionVariables.set(\"orderId\", jsonData.id);",
                  "    console.log(\"Order ID: \" + jsonData.id + \" has been set.\");",
                  "}",
                  "if (jsonData.clientCpf) {",
                  "    pm.collectionVariables.set(\"cpfData\", jsonData.clientCpf);",
                  "    console.log(\"Order CPF: \" + jsonData.clientCpf + \" has been set.\");",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
